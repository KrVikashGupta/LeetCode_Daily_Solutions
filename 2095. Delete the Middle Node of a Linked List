class Solution {
    public ListNode deleteMiddle(ListNode head) {
        if(head == null || head.next == null) return null;
        ListNode fast = head;
        ListNode middle = head;
        ListNode prev = null;
        while(fast != null && fast.next!= null){
            prev = middle;
            fast = fast.next.next;
            middle = middle.next;
        }
        if(prev == null) return null;
        prev.next = middle.next;
        return head;
    }
}     
 
